		{"id":"080da3f8b875d996","type":"text","text":"# MIMOŘÁDNÉ SHROMÁŽDĚNÍ DELEGÁTŮ","x":-1339,"y":-837,"width":541,"height":60},
		{"id":"bbd351eab5a2e109","type":"text","text":"# a mimochodem, bylo to správně","x":-1859,"y":-2900,"width":464,"height":50},
		{"id":"ce76afcd1e0ea04b","type":"text","text":"DESTABILIZACE SPOLKU","x":-1757,"y":-2460,"width":250,"height":60},
		{"id":"96434ad795be7851","type":"text","text":"PŘEPIS ZÁPISU ! SCHŮZE VÝBORU","x":-1685,"y":-2711,"width":290,"height":50},
		{"id":"a946c162f2e4ccc1","type":"text","text":"NEFUNKČNOST SPOLKU","x":-1757,"y":-2380,"width":250,"height":60},
		{"id":"4b50fb56d5f29acd","type":"text","text":"FINANČNÍ VRAŽDA","x":-1757,"y":-2300,"width":250,"height":50},
		{"id":"16ecd6ff76c7aa27","type":"text","text":"# Žalobci se prezentují jako oběti","x":-1698,"y":-1861,"width":440,"height":50},
		{"id":"6f2f827257eab20b","type":"text","text":"NOVÁ SMĚRNICE AKTUALZUJÍCÍ TU STAROU","x":-2000,"y":-2661,"width":250,"height":61},
		{"id":"026531835ade0268","type":"text","text":"SMĚRNICE","x":-1920,"y":-2761,"width":148,"height":50},
		{"id":"156e64050727f14e","type":"text","text":"**čl. IV odst. 2 písmeno ačlen spolku je povinnen dodržovat stanovy a organizační řád spolku a další interní předpisy...**","x":-2551,"y":-2900,"width":412,"height":100},
		{"id":"a4ac59ab4d93dca7","type":"text","text":"**výbor spolku navrhuje a schvaluje interní organizační normy spolku**","x":-2551,"y":-2780,"width":375,"height":60},
		{"id":"2714f8cb2dbb4ad2","type":"text","text":"# zpochybnění dobré vůle žalobců","x":-2511,"y":-2328,"width":292,"height":117},
