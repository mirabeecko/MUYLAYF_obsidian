		{"id":"6fb3c9a2c4be1240","type":"file","file":"80 🎪 TJ/GPT TJ ZADÁNÍ.md","x":-3965,"y":-680,"width":375,"height":756},
		{"id":"bd8e2ba79917a265","type":"text","text":"MYSLIM TO VÁŽNĚ - NIKDY NIKDO NEMŮŽE .\nVŠECHNO CO ŘIKÁM, DOLOŽIM. \nONI JSOU JASNÝ PODĚLKY - ZPRONEVĚRA PENĚZ, NEUHRAZENÍ NÁKLADŮ ZA PROVOZ\n\n# DAL JSEM JIM VŠECHNY ŠANCE , CO ŠLI A ONI SE KE MNĚ CHOVAJ JAKO K MRDCE\n\n# udělali to úplně blběs","x":4045,"y":938,"width":753,"height":289},
