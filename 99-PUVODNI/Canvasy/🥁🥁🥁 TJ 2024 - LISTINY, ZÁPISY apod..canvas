		{"id":"163b2d1c150469ae","type":"text","text":"### článek 9 - odst. 5 \n- Zdroje majetku spolku tvoří zejména *a) příspěvky od členů spolku*","x":5298,"y":1385,"width":395,"height":130,"color":"1"},
		{"id":"17071b68865acfad","type":"text","text":"FALŠOVÁNÍ DOKLADŮ","x":5386,"y":1640,"width":259,"height":50},
