		{"id":"32ddd9f433e088ac","type":"text","text":"### STRATEGIE","x":-540,"y":-560,"width":180,"height":50,"color":"4"},
		{"id":"9a2e8073b75529e8","type":"text","text":"NEDĚLEJ TU CHYBU, ŽE SI ZASEREŠ HLAVU TÍM BORDELEM MÁŠ SVATOU PRAVDU O MOJÍ \"OBHAJOBĚ\", *JÁ SI TO NEPŘEJU, VÁŽNĚ*. ","x":-852,"y":-422,"width":272,"height":166},
