		{"id":"9fa3f1eefce73809","type":"text","text":"Obsahuje podpisy lidí, kteří nikdy členy nebyli","x":-2179,"y":-1470,"width":209,"height":50},
		{"id":"854db178ee13f2c9","type":"text","text":"LYŽAŘI","x":-1930,"y":-2150,"width":164,"height":50},
		{"id":"0a9c0411ecfc9f23","type":"text","text":"- 43 ČLENŮ\n- 21 PODPISŮ\n- ","x":-1727,"y":-2260,"width":175,"height":84},
		{"id":"140a2688dac4d4eb","type":"text","text":"- 36 ČLENŮ\n- 29 PODPISŮ\n- ### 23x děti\n- z 36 členů, které nikdy jako členy nenahlásili, mají stejně platných pouze 6 podpisů, jelikož jsou dle dat narození stále děti pod 18 let.","x":-1692,"y":-1965,"width":294,"height":208},
