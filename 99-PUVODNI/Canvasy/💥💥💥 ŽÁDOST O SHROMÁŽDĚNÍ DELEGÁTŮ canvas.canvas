		{"id":"145690e56a0dc742","type":"text","text":"#### VÁŽENÝ PANE ROUSKU, JE POTŘEBA VÁS UVÉST V OBRAZ","x":-1494,"y":-900,"width":322,"height":80,"color":"4"},
		{"id":"7d7282d554a61999","type":"text","text":"PŘEDSEDA ODDÍLU A VÝBOR ODDÍLU, SE MÁ VOLIT KAŽDÝ ROK NA ČLENSKÉ SCHŮZI.","x":-1112,"y":-898,"width":250,"height":78,"color":"3"},
